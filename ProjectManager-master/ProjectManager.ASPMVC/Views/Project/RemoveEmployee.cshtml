@model ProjectManager.ASPMVC.Models.Project.RemoveEmployeeForm

@{
    ViewData["Title"] = "Retirer un employé";
}

<h1>Retirer un employé</h1>

<h3>Êtes-vous sûr-e de vouloir enlever cet employee du projet ?</h3>
<div>
    <h4>RemoveEmployeeForm</h4>
    <hr />
    <dl class="row">

        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.EmployeeId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.EmployeeId)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ProjectId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ProjectId)
        </dd>
    </dl>
    
    <form asp-action="RemoveEmployee">
        <input type="submit" value="Retirer du projet" class="btn btn-danger" /> |
        <input type="hidden" asp-for="ProjectId" />
        <input type="hidden" asp-for="EmployeeId" />
        <a asp-action="Details" asp-controller="Project" asp-route-id="@Model.ProjectId">Revenir au projet</a>


    </form>
</div>
