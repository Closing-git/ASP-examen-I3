@model ProjectManager.ASPMVC.Models.Project.DetailsViewModel
@using ProjectManager.ASPMVC.Handlers
@inject UserSessionManager userSession

@{
    ViewData["Title"] = Model.Name;
}

<h1>@Model.Name</h1>

<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        @if (userSession.IsProjectManager is not null and true)
        {
        <button>
            <a class="nav-link text-dark" asp-area="" asp-controller="Project" asp-action="Edit" asp-route-id="@Model.ProjectId">Editer la description</a>
        </button>
        }
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CreationDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CreationDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ProjectManagerName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ProjectManagerName)
        </dd>
        <dt class="col-sm-2">
            <p>Membres de l'équipe</p>
        </dt>
        <dd class="col-sm-10">
            <ul>
            @foreach (var member in Model.TeamMembers)
            {
                    <li>@member.Name</li>
                    <button>
                        <a class="nav-link text-dark" asp-area="" asp-controller="Project" asp-action="RemoveEmployee" asp-route-projectId="@Model.ProjectId"  asp-route-employeeId="@member.EmployeeId">🗑️</a>
                    </button>
            }
            </ul>
        </dd>
    </dl>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        Posts du projet
                    </h4>
                    <button>
                        <a class="nav-link text-dark" asp-area="" asp-controller="Post" asp-action="Create" asp-route-id="@Model.ProjectId">Ecrire un nouveau post</a>
                    </button>
                </div>
                <div class="card-body">
                    @if (Model.Posts is not null)
                    {
                        <div class="timeline">
                            @foreach (var post in Model.Posts)
                            {
                                <div class="timeline-item mb-4">
                                    <div class="timeline-header d-flex justify-content-between">
                                        <div>
                                            <strong>@post.AuthorName</strong>
                                            <small class="text-muted ms-2">@post.AuthorEmail</small>
                                        </div>
                                        <small class="text-muted">@post.SendDate.ToString("dd/MM/yyyy HH:mm")</small>
                                    </div>
                                    <div class="timeline-content mt-2">
                                        <h6>@post.Subject</h6>
                                        <p class="mb-0">@post.Content</p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

</div>
<div>

    <a asp-action="Index">Revenir à la liste</a>
</div>
